# Copy this file to `.env` (same directory as docker-compose.yml) and adjust if needed.
# Docker Compose loads it automatically. All values have safe defaults for local development.

# =============================================================================
# Required overrides for staging / production
# =============================================================================

# ---- Postgres ----
# The DATABASE_URL the backend sees is built from these three values.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=logistica

# ---- Django ----
# Replace with a strong, randomly generated value in any non-dev environment.
DJANGO_SECRET_KEY=dev-only-not-secret

# Set to `False` outside of local development.
DJANGO_DEBUG=True

# Comma-separated list. Use `*` only locally; restrict to the real hostname(s) in staging / prod.
DJANGO_ALLOWED_HOSTS=*

# ---- Frontend ----
# Public backend URL as seen from the host browser.
VITE_API_URL=http://localhost:8000

# Comma-separated list of allowed CORS origins. Add the public frontend URL when deploying.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# =============================================================================
# Optional — sensible defaults are applied when left unset
# =============================================================================

# Base URL of the frontend. Embedded in verification / password-reset email links.
# Default: http://localhost:5173
#FRONTEND_BASE_URL=

# ---- Email (SMTP) ----
# Dev defaults to the console backend, which prints emails to stdout instead of
# sending them. For staging / prod, switch the backend and fill in the SMTP details.
# Defaults:
#   EMAIL_BACKEND     = django.core.mail.backends.console.EmailBackend
#   EMAIL_PORT        = 587
#   EMAIL_USE_TLS     = True
#   DEFAULT_FROM_EMAIL= no-reply@logistica.local
#EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
#EMAIL_HOST=
#EMAIL_PORT=587
#EMAIL_HOST_USER=
#EMAIL_HOST_PASSWORD=
#EMAIL_USE_TLS=True
#DEFAULT_FROM_EMAIL=no-reply@logistica.local

# ---- Tracking provider ----
# Dotted path to the active TrackingProvider implementation.
# See apps/tracking/providers/ and docs/adr/0002-tracking-provider.md in the backend repo.
# Default: apps.tracking.providers.mock.MockTrackingProvider
#TRACKING_PROVIDER=

# ---- Observability / debugging ----
# Root log level (DEBUG, INFO, WARNING, ERROR). Default: INFO
#LOG_LEVEL=

# Force synchronous execution of Celery tasks (useful for debugging only).
# Default: False
#CELERY_TASK_ALWAYS_EAGER=
