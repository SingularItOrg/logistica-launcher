# Copy this file to `.env` (same directory as docker-compose.yml) and adjust if needed.
# Docker Compose loads it automatically. All values have defaults.

# ---- Postgres ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=logistica

# ---- Backend (Django) ----
DJANGO_SECRET_KEY=dev-only-not-secret
# Allowed CORS origins. In dev this matches the frontend URL.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ---- Frontend (Vite) ----
# Public backend URL, as seen from the host browser.
VITE_API_URL=http://localhost:8000
